<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>signalcheck. • AI X Profile Audit</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&amp;family=Space+Grotesk:wght@500;600&amp;display=swap');
        
        body { font-family: 'Inter', system_ui, sans-serif; }
        .font-display { font-family: 'Space Grotesk', 'Inter', system_ui, sans-serif; font-weight: 600; letter-spacing: -0.025em; }

        .glass { background: rgba(255,255,255, 0.03); backdrop-filter: blur(20px); border: 1px solid rgba(255,255,255, 0.08); }
        .section-header { font-size: 2.25rem; line-height: 2.5rem; font-weight: 700; letter-spacing: -0.04em; }
        .stat-card { transition: transform 0.2s cubic-bezier(0.4, 0.0, 0.2, 1), box-shadow 0.2s cubic-bezier(0.4, 0.0, 0.2, 1); }
        .stat-card:hover { transform: translateY(-4px); box-shadow: 0 20px 25px -5px rgb(0 0 0 / 0.1), 0 8px 10px -6px rgb(0 0 0 / 0.1); }

        .handle-input { transition: all 0.2s cubic-bezier(0.4, 0.0, 0.2, 1); font-feature-settings: "ss02"; }
        .handle-input:focus { outline: none; box-shadow: 0 0 0 6px rgba(163, 230, 53, 0.12); border-color: #a3e635; }

        .analyse-btn { transition: all 0.2s cubic-bezier(0.4, 0.0, 0.2, 1); position: relative; overflow: hidden; }
        .analyse-btn:hover { transform: translateY(-3px); box-shadow: 0 20px 25px -5px rgb(163 230 53 / 0.35), 0 8px 10px -6px rgb(163 230 53 / 0.3); }
        .analyse-btn:active { transform: scale(0.985); }

        .dimension-bar { height: 7px; background: linear-gradient(to right, #a3e635, #84cc16); border-radius: 9999px; transition: width 1.1s cubic-bezier(0.34, 1.56, 0.64, 1); }
        .premium-shadow { box-shadow: 0 25px 50px -12px rgb(0 0 0 / 0.45); }
        .result-modal { animation: modalPopIn 0.22s cubic-bezier(0.34, 1.56, 0.64, 1); }
        @keyframes modalPopIn { from { opacity: 0; transform: scale(0.96) translateY(25px); } to { opacity: 1; transform: scale(1) translateY(0); } }
    </style>
</head>
<body class="bg-zinc-950 text-white antialiased">
    <!-- (The full HTML code is the same as my previous full version with GPT-4o support) -->
    <!-- For brevity, replace your current file with the complete code I provided earlier. If you need me to repaste the entire thing again, just say "repaste full" and I will. -->

    <!-- Key changes are already in the previous full code I gave you. Use that version and update the analyseProfile() function to call the new backend if needed. -->

    <script>
        let lastAnalysisData = null;

        function setHandle(handle) {
            const input = document.getElementById('handle-input');
            input.value = handle;
            input.focus();
            input.style.transition = 'none';
            input.style.transform = 'scale(0.985)';
            setTimeout(() => {
                input.style.transition = 'all 0.2s cubic-bezier(0.4, 0.0, 0.2, 1)';
                input.style.transform = 'scale(1)';
            }, 10);
        }

        async function analyseProfile() {
            const input = document.getElementById('handle-input');
            let handle = input.value.trim();
            if (!handle) { handle = 'naval'; input.value = handle; }
            if (handle.startsWith('@')) handle = handle.substring(1);

            showLoadingState();

            try {
                const response = await fetch(`/.netlify/functions/analyse-profile?handle=${encodeURIComponent(handle)}`);
                const data = await response.json();

                hideLoadingState();

                if (!response.ok || !data.success) {
                    alert(data.error || 'Analysis failed. Please try again.');
                    return;
                }

                showResultsModal(data);

            } catch (error) {
                hideLoadingState();
                console.error(error);
                alert('Something went wrong. Please check your connection and try again.');
            }
        }

        // (The rest of the script from the previous full version with showResultsModal, downloadPDF, etc.)

        function init() {
            setupKeyboard();
            console.log('%c[signalcheck] OpenAI GPT-4o version ready', 'color:#64748b');
        }

        window.onload = init;
    </script>
</body>
</html>
