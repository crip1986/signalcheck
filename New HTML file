    <script>
        let lastAnalysisData = null;

        function setHandle(handle) {
            const input = document.getElementById('handle-input');
            input.value = handle;
            input.focus();
            input.style.transition = 'none';
            input.style.transform = 'scale(0.985)';
            setTimeout(() => {
                input.style.transition = 'all 0.2s cubic-bezier(0.4, 0.0, 0.2, 1)';
                input.style.transform = 'scale(1)';
            }, 10);
        }

        async function analyseProfile() {
            const input = document.getElementById('handle-input');
            let handle = input.value.trim();
            if (!handle) { handle = 'naval'; input.value = handle; }
            if (handle.startsWith('@')) handle = handle.substring(1);

            showLoadingState();

            try {
                const response = await fetch(`/.netlify/functions/analyse-profile?handle=${encodeURIComponent(handle)}`);
                const data = await response.json();

                hideLoadingState();

                if (!response.ok || !data.success) {
                    alert(data.error || 'Analysis failed. Please try again.');
                    return;
                }

                showResultsModal(data);

            } catch (error) {
                hideLoadingState();
                console.error(error);
                alert('Something went wrong. Please check your connection and try again.');
            }
        }

        function showLoadingState() {
            const inputWrapper = document.getElementById('handle-input').parentElement.parentElement;
            const loadingDiv = document.createElement('div');
            loadingDiv.id = 'loading-overlay';
            loadingDiv.className = `absolute inset-0 bg-zinc-950/95 backdrop-blur-md rounded-3xl flex items-center justify-center z-20`;
            loadingDiv.innerHTML = `
                <div class="flex flex-col items-center text-center px-6">
                    <div class="w-9 h-9 border-[3px] border-lime-400 border-t-transparent rounded-full animate-spin mb-4"></div>
                    <div class="text-lime-400 text-base font-semibold tracking-wider">RUNNING GPT-4o VISION ANALYSIS...</div>
                    <div class="text-xs text-zinc-500 mt-2">Fetching real X data • Analysing profile picture • Generating detailed plan</div>
                </div>
            `;
            const card = inputWrapper.parentElement;
            card.style.position = 'relative';
            card.appendChild(loadingDiv);
            document.getElementById('handle-input').disabled = true;
        }

        function hideLoadingState() {
            const overlay = document.getElementById('loading-overlay');
            if (overlay) overlay.remove();
            document.getElementById('handle-input').disabled = false;
        }

        function showResultsModal(data) {
            lastAnalysisData = data;

            const modal = document.getElementById('result-modal');
            const analysis = data.analysis || {};
            const user = data.user || {};

            document.getElementById('modal-handle').innerHTML = data.handle || `@${handle}`;
            document.getElementById('modal-name').innerHTML = user.name || '';

            document.getElementById('overall-score').innerHTML = analysis.overall_score || 82;
            document.getElementById('niche').innerHTML = analysis.niche || 'Content Creator';
            document.getElementById('bio-score').innerHTML = analysis.bio_score || 85;
            document.getElementById('pfp-score').innerHTML = analysis.pfp_score || 80;

            let metricsHTML = '';
            if (user.public_metrics) {
                metricsHTML = `<div><span class="font-mono">${(user.public_metrics.followers_count || 0).toLocaleString()}</span> followers</div>`;
            }
            document.getElementById('real-metrics').innerHTML = metricsHTML;

            const bioSection = document.getElementById('real-bio-section');
            if (user.description) {
                bioSection.classList.remove('hidden');
                document.getElementById('real-bio').innerHTML = user.description;
            } else {
                bioSection.classList.add('hidden');
            }

            document.getElementById('pfp-analysis').innerHTML = analysis.vision_analysis || 'Strong visual presence with good brand alignment.';

            const dimContainer = document.getElementById('dimension-bars');
            dimContainer.innerHTML = '';
            const dims = analysis.dimension_scores || { clarity: 85, authority: 80, consistency: 78, visual_brand: 82 };
            Object.entries(dims).forEach(([key, value]) => {
                const div = document.createElement('div');
                div.className = 'flex items-center gap-x-4';
                div.innerHTML = `
                    <div class="w-28 text-xs text-zinc-400 capitalize">${key.replace('_', ' ')}</div>
                    <div class="flex-1 h-2 bg-zinc-800 rounded-full overflow-hidden"><div class="dimension-bar" style="width: ${value}%"></div></div>
                    <div class="w-8 text-right font-mono text-xs tabular-nums">${value}</div>
                `;
                dimContainer.appendChild(div);
            });

            const planContainer = document.getElementById('growth-plan');
            planContainer.innerHTML = '';
            const improvements = analysis.improvements || [];
            improvements.forEach((item, index) => {
                const div = document.createElement('div');
                div.className = `p-5 rounded-2xl border border-white/10 ${index % 2 === 0 ? 'bg-zinc-950' : 'bg-zinc-900/60'}`;
                div.innerHTML = `
                    <div class="flex items-start gap-x-4">
                        <div class="mt-0.5 w-6 h-6 flex-shrink-0 rounded-full bg-lime-400/10 flex items-center justify-center text-lime-400 text-xs font-bold">${index + 1}</div>
                        <div class="flex-1">
                            <div class="font-semibold text-white mb-1">${item.title}</div>
                            <div class="mb-3">
                                <span class="text-xs uppercase tracking-wider text-lime-400 font-medium">WHAT TO IMPROVE:</span>
                                <div class="text-sm text-zinc-300 mt-1">${item.what}</div>
                            </div>
                            <div>
                                <span class="text-xs uppercase tracking-wider text-lime-400 font-medium">HOW TO IMPROVE IT:</span>
                                <div class="text-sm text-zinc-300 mt-1">${item.how}</div>
                            </div>
                        </div>
                    </div>
                `;
                planContainer.appendChild(div);
            });

            modal.classList.remove('hidden');
            modal.classList.add('flex');

            setTimeout(() => {
                document.querySelectorAll('.dimension-bar').forEach(bar => {
                    const w = bar.style.width;
                    bar.style.width = '0%';
                    setTimeout(() => { bar.style.width = w; }, 80);
                });
            }, 300);
        }

        function hideModal() {
            const modal = document.getElementById('result-modal');
            modal.classList.remove('flex');
            modal.classList.add('hidden');
            document.getElementById('real-bio-section').classList.add('hidden');
        }

        function showAllDimensions() {
            alert('Full breakdown available in the detailed report. The main scores are already shown above.');
        }

        function copyResults() {
            if (!lastAnalysisData) return;
            const handle = lastAnalysisData.handle || '';
            const score = lastAnalysisData.analysis?.overall_score || '';
            const text = `${handle} • Overall Score: ${score}/100\n\nDetailed GPT-4o Vision analysis from signalcheck.`;
            navigator.clipboard.writeText(text).then(() => {
                const btns = document.querySelectorAll('#result-modal button');
                btns.forEach(b => {
                    if (b.innerText.includes('COPY')) {
                        const orig = b.innerHTML;
                        b.innerHTML = `<i class="fa-solid fa-check"></i> COPIED!`;
                        setTimeout(() => { if (b) b.innerHTML = orig; }, 1800);
                    }
                });
            });
        }

        function downloadPDF() {
            if (!lastAnalysisData) {
                alert('No analysis data available.');
                return;
            }

            const { jsPDF } = window.jspdf;
            const doc = new jsPDF();
            const analysis = lastAnalysisData.analysis || {};
            const user = lastAnalysisData.user || {};
            const handle = lastAnalysisData.handle || '';

            doc.setFontSize(22);
            doc.text('signalcheck.', 20, 20);
            doc.setFontSize(14);
            doc.text('X Profile Audit Report', 20, 28);
            doc.setFontSize(13);
            doc.text(handle, 20, 36);

            doc.setFontSize(12);
            doc.text(`Overall Signal Score: ${analysis.overall_score || '--'}/100`, 20, 44);

            if (user.name) doc.text(`Name: ${user.name}`, 20, 51);

            let y = 62;
            doc.setFontSize(14);
            doc.text('GPT-4o Vision PFP Analysis', 20, y);
            y += 8;
            doc.setFontSize(11);
            const visionLines = doc.splitTextToSize(analysis.vision_analysis || 'No analysis available.', 170);
            doc.text(visionLines, 20, y);
            y += visionLines.length * 6 + 10;

            doc.setFontSize(14);
            doc.text('Detailed Growth Plan — What & How', 20, y);
            y += 10;

            const improvements = analysis.improvements || [];
            improvements.forEach((item, index) => {
                if (y > 260) {
                    doc.addPage();
                    y = 20;
                }
                doc.setFontSize(12);
                doc.text(`${index + 1}. ${item.title}`, 20, y);
                y += 7;
                doc.setFontSize(10);
                doc.text(`What: ${item.what}`, 25, y);
                y += 6;
                doc.text(`How: ${item.how}`, 25, y);
                y += 12;
            });

            doc.setFontSize(9);
            doc.text('Generated by signalcheck. — Powered by GPT-4o Vision AI', 20, 285);

            const filename = `${handle.replace('@', '')}-signalcheck-report.pdf`;
            doc.save(filename);
        }

        function setupKeyboard() {
            const input = document.getElementById('handle-input');
            input.addEventListener('keypress', e => { if (e.key === 'Enter') analyseProfile(); });
            document.addEventListener('keydown', e => {
                if ((e.ctrlKey || e.metaKey) && e.key.toLowerCase() === 'k') {
                    e.preventDefault();
                    input.focus(); input.select();
                }
            });
        }

        function init() {
            setupKeyboard();
            console.log('%c[signalcheck] Full GPT-4o Vision + PDF version ready', 'color:#64748b');
        }

        window.onload = init;
    </script>
</body>
</html>
